#!/bin/bash
set -e

echo "=== Pre-commit checks ==="

# 1. Format check
echo "[1/3] Checking formatting..."
cargo fmt -- --check
if [ $? -ne 0 ]; then
    echo "ERROR: Code is not formatted. Run 'cargo fmt' first."
    exit 1
fi

# 2. Lint (clippy)
echo "[2/3] Running clippy..."
cargo clippy -- -D warnings 2>&1 | head -50
if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "ERROR: Clippy warnings found. Fix them before committing."
    exit 1
fi

# 3. Quick tests (lib tests only, not integration — those are too slow)
echo "[3/3] Running lib tests..."
cargo test --lib
if [ $? -ne 0 ]; then
    echo "ERROR: Lib tests failed."
    exit 1
fi

echo "=== All pre-commit checks passed ==="
